# ============================================================
# OracleX — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# X Layer RPC
RPC_URL=https://rpc.xlayer.tech
CHAIN_ID=196

# Testnet (for testing before mainnet)
TESTNET_RPC_URL=https://testrpc.xlayer.tech
TESTNET_CHAIN_ID=195

# Contract Addresses (fill after deployment)
FACTORY_ADDRESS=
PREDICTION_MARKET_IMPL_ADDRESS=

# Agent Wallets
# Creator Agent deploys markets, injects liquidity
CREATOR_PRIVATE_KEY=0x_your_creator_key_here
# Resolver Agent settles markets via OKX price
RESOLVER_PRIVATE_KEY=0x_your_resolver_key_here
# Platform wallet receives 2% fee
PLATFORM_WALLET=0x_your_platform_wallet_here

# OKX Market API (public endpoints — no key required for price data)
OKX_REST_BASE=https://www.okx.com/api/v5
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public

# OKX OnchainOS API (DEX Aggregator V6 + Wallet API)
# Get your keys at https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Claude AI — Signal Agent brain
CLAUDE_API_KEY=your-api-key-here
# Optional: OpenAI-compatible proxy URL
# CLAUDE_BASE_URL=https://your-proxy.com
# Model name (default: gpt-4o-mini)
# CLAUDE_MODEL=gpt-4o-mini

# API Server
PORT=3001

# Frontend (Next.js public vars)
NEXT_PUBLIC_CHAIN_ID=196
NEXT_PUBLIC_RPC_URL=https://rpc.xlayer.tech
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_EXPLORER=https://www.oklink.com/xlayer
